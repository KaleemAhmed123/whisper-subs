# ══════════════════════════════════════════════════
#  Whisper Subtitle Generator — Configuration
#  Edit this file before running generate.bat
# ══════════════════════════════════════════════════

# Path to your folder containing video files
# Use forward slashes (works on all drives)
# Examples:
#   C:/Users/YourName/Videos
#   D:/My Course Videos
#   E:/Lectures/Urdu Series
VIDEO_FOLDER=D:\GOTO_CNTNT\1. Akhiri Moujza\6-12


# ── Model ──────────────────────────────────────────
# tiny     ~39MB   fastest, lower accuracy
# base     ~74MB   fast, good for clear audio
# small    ~244MB  good balance (recommended for CPU)
# medium   ~769MB  best balance  (recommended for GPU)
# large-v3 ~1.5GB  highest accuracy, slowest
MODEL=medium

# ── Language ───────────────────────────────────────
# Use ISO 639-1 codes: en, ur, ar, hi, fr, de, zh...
# Use "auto" to let Whisper detect the language
# Common codes: en=English, ur=Urdu, ar=Arabic, hi=Hindi
LANGUAGE=ur

# ── Skip existing ──────────────────────────────────
# true  = skip videos that already have subtitle files (safe to re-run)
# false = regenerate subtitles for all videos
SKIP_EXISTING=true

# ── Output format ──────────────────────────────────
# srt   = SubRip (.srt)  — most compatible, works in VLC, MPC, Plex
# vtt   = WebVTT (.vtt)  — web players, HTML5
# both  = generate both .srt and .vtt
OUTPUT_FORMAT=srt

# ── Hinglish  ──────────────────────────────────────
# true  = Convert Hindi/Urdu to Roman alphabet (Hinglish)
# HINGLISH=true

# ── HuggingFace Token (optional) ───────────────────
# Speeds up model downloads with higher rate limits.
# Get your free token at: https://huggingface.co/settings/tokens
# Paste it below and remove the leading #
# HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
